generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserRole {
  id     String   @id @default(cuid())
  userId String
  role   RoleType
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model Company {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique
  address         String?
  phone           String?
  email           String?
  isActive        Boolean           @default(true)
  ownerId         String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  status          CompanyStatus     @default(ACTIVE)
  suspendedAt     DateTime?
  suspendedReason String?
  suspendedUntil  DateTime?
  deletedAt       DateTime?
  deletedReason   String?
  accounts        Account[]
  owner           User              @relation("CompanyOwner", fields: [ownerId], references: [id])
  settings        CompanySetting[]
  jadwalAngsuran  JadwalAngsuran[]
  journalEntries  JournalEntry[]
  kasKategori     KasKategori[]
  kasTransaksi    KasTransaksi[]
  kelompok        Kelompok[]
  kolektorTargets KolektorTarget[]
  nasabah         Nasabah[]
  notifikasi      Notifikasi[]
  pembayaran      Pembayaran[]
  pengajuan       Pengajuan[]
  penjamin        Penjamin[]
  pinjaman        Pinjaman[]
  rekonsiliasi    RekonsiliasiKas[]
  simpanan        Simpanan[]
  users           User[]            @relation("UserCompany")

  @@index([ownerId])
  @@map("companies")
}

model User {
  id                     String            @id @default(cuid())
  name                   String
  email                  String            @unique
  password               String
  isActive               Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  companyId              String?
  approvalApproved       ApprovalLog[]     @relation("ApprovalApprover")
  approvalRequested      ApprovalLog[]     @relation("ApprovalRequester")
  auditLogs              AuditLog[]        @relation("AuditActor")
  ownedCompanies         Company[]         @relation("CompanyOwner")
  journalPosted          JournalEntry[]    @relation("JournalPostedBy")
  kasDiinput             KasTransaksi[]
  kolektorTargets        KolektorTarget[]  @relation("KolektorTargetUser")
  nasabahSebagaiKolektor Nasabah[]         @relation("KolektorNasabah")
  notifikasi             Notifikasi[]      @relation("UserNotifikasi")
  pembayaranDiinput      Pembayaran[]
  pengajuanDisetujui     Pengajuan[]       @relation("ApproverPengajuan")
  pengajuanDisurvey      Pengajuan[]       @relation("SurveyorPengajuan")
  rekonsiliasiDibuat     RekonsiliasiKas[] @relation("RekonsiliasiCreatedBy")
  roles                  UserRole[]
  company                Company?          @relation("UserCompany", fields: [companyId], references: [id])

  @@index([companyId])
  @@map("users")
}

model Nasabah {
  id            String        @id @default(cuid())
  nomorAnggota  String
  namaLengkap   String
  nik           String
  tempatLahir   String?
  tanggalLahir  DateTime?
  alamat        String
  kelurahan     String?
  kecamatan     String?
  kotaKab       String?
  noHp          String
  pekerjaan     String?
  namaUsaha     String?
  status        StatusNasabah @default(AKTIF)
  tanggalGabung DateTime      @default(now())
  fotoUrl       String?
  dokumenUrls   String[]
  kolektorId    String?
  kelompokId    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  kelompok      Kelompok?     @relation(fields: [kelompokId], references: [id])
  kolektor      User?         @relation("KolektorNasabah", fields: [kolektorId], references: [id])
  pengajuan     Pengajuan[]
  penjamin      Penjamin[]
  simpanan      Simpanan[]

  @@unique([companyId, nomorAnggota])
  @@unique([companyId, nik])
  @@index([companyId])
  @@map("nasabah")
}

model Penjamin {
  id          String  @id @default(cuid())
  namaLengkap String
  nik         String
  hubungan    String
  noHp        String
  alamat      String?
  nasabahId   String
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nasabah     Nasabah @relation(fields: [nasabahId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("penjamin")
}

model Kelompok {
  id              String      @id @default(cuid())
  kode            String
  nama            String
  ketua           String?
  wilayah         String?
  jadwalPertemuan String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nasabah         Nasabah[]
  pengajuan       Pengajuan[]

  @@unique([companyId, kode])
  @@index([companyId])
  @@map("kelompok")
}

model Pengajuan {
  id                   String          @id @default(cuid())
  nomorPengajuan       String          @unique @default(cuid())
  nasabahId            String
  kelompokId           String?
  jenisPinjaman        JenisPinjaman   @default(REGULAR)
  plafonDiajukan       Decimal         @db.Decimal(15, 2)
  plafonDisetujui      Decimal?        @db.Decimal(15, 2)
  tenor                Int
  bungaPerBulan        Decimal         @db.Decimal(5, 4)
  tujuanPinjaman       String?
  agunan               String?
  hasilSurvey          String?
  catatanApproval      String?
  status               StatusPengajuan @default(DRAFT)
  tanggalPengajuan     DateTime        @default(now())
  tanggalSurvey        DateTime?
  tanggalApproval      DateTime?
  surveyorId           String?
  approverId           String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  tenorType            TenorType       @default(BULANAN)
  catatanPengajuan     String?
  dokumenPendukungUrls String[]        @default([])
  companyId            String
  approver             User?           @relation("ApproverPengajuan", fields: [approverId], references: [id])
  company              Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  kelompok             Kelompok?       @relation(fields: [kelompokId], references: [id])
  nasabah              Nasabah         @relation(fields: [nasabahId], references: [id])
  surveyor             User?           @relation("SurveyorPengajuan", fields: [surveyorId], references: [id])
  pinjaman             Pinjaman?

  @@index([companyId])
  @@map("pengajuan")
}

model Pinjaman {
  id                String           @id @default(cuid())
  nomorKontrak      String           @unique
  pengajuanId       String           @unique
  pokokPinjaman     Decimal          @db.Decimal(15, 2)
  tenor             Int
  bungaPerBulan     Decimal          @db.Decimal(5, 4)
  angsuranPokok     Decimal          @db.Decimal(15, 2)
  angsuranBunga     Decimal          @db.Decimal(15, 2)
  totalAngsuran     Decimal          @db.Decimal(15, 2)
  potonganAdmin     Decimal          @default(0) @db.Decimal(15, 2)
  potonganProvisi   Decimal          @default(0) @db.Decimal(15, 2)
  nilaiCair         Decimal          @db.Decimal(15, 2)
  tanggalCair       DateTime
  tanggalJatuhTempo DateTime
  sisaPinjaman      Decimal          @db.Decimal(15, 2)
  status            StatusPinjaman   @default(AKTIF)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tenorType         TenorType        @default(BULANAN)
  companyId         String
  jadwalAngsuran    JadwalAngsuran[]
  pembayaran        Pembayaran[]
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pengajuan         Pengajuan        @relation(fields: [pengajuanId], references: [id])

  @@index([companyId])
  @@map("pinjaman")
}

model JadwalAngsuran {
  id                String    @id @default(cuid())
  pinjamanId        String
  angsuranKe        Int
  tanggalJatuhTempo DateTime
  pokok             Decimal   @db.Decimal(15, 2)
  bunga             Decimal   @db.Decimal(15, 2)
  total             Decimal   @db.Decimal(15, 2)
  sudahDibayar      Boolean   @default(false)
  tanggalBayar      DateTime?
  dendaHarian       Decimal   @default(0) @db.Decimal(15, 2)
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pinjaman          Pinjaman  @relation(fields: [pinjamanId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("jadwal_angsuran")
}

model Pembayaran {
  id             String      @id @default(cuid())
  nomorTransaksi String      @unique @default(cuid())
  pinjamanId     String
  tanggalBayar   DateTime    @default(now())
  pokok          Decimal     @db.Decimal(15, 2)
  bunga          Decimal     @db.Decimal(15, 2)
  denda          Decimal     @default(0) @db.Decimal(15, 2)
  totalBayar     Decimal     @db.Decimal(15, 2)
  metode         MetodeBayar @default(TUNAI)
  catatan        String?
  inputOlehId    String
  isBatalkan     Boolean     @default(false)
  alasanBatal    String?
  createdAt      DateTime    @default(now())
  buktiBayarUrl  String?
  companyId      String
  company        Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inputOleh      User        @relation(fields: [inputOlehId], references: [id])
  pinjaman       Pinjaman    @relation(fields: [pinjamanId], references: [id])

  @@index([companyId])
  @@map("pembayaran")
}

model Simpanan {
  id        String   @id @default(cuid())
  nasabahId String
  jenis     String
  jumlah    Decimal  @db.Decimal(15, 2)
  tanggal   DateTime @default(now())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nasabah   Nasabah  @relation(fields: [nasabahId], references: [id])

  @@index([companyId])
  @@map("simpanan")
}

model Account {
  id           String            @id @default(cuid())
  code         String
  name         String
  type         AccountType
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journalLines JournalLine[]
  kasKategori  KasKategori[]
  rekonsiliasi RekonsiliasiKas[]

  @@unique([companyId, code])
  @@index([type, isActive])
  @@index([companyId])
  @@map("accounts")
}

model JournalEntry {
  id          String            @id @default(cuid())
  entryNo     String            @unique @default(cuid())
  entryDate   DateTime
  description String
  sourceType  JournalSourceType
  sourceId    String?
  status      JournalStatus     @default(POSTED)
  postedById  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  postedBy    User?             @relation("JournalPostedBy", fields: [postedById], references: [id])
  lines       JournalLine[]

  @@unique([sourceType, sourceId])
  @@index([entryDate])
  @@index([sourceType, sourceId])
  @@index([companyId])
  @@map("journal_entries")
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal      @default(0) @db.Decimal(15, 2)
  credit         Decimal      @default(0) @db.Decimal(15, 2)
  memo           String?
  createdAt      DateTime     @default(now())
  account        Account      @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_lines")
}

model RekonsiliasiKas {
  id             String             @id @default(cuid())
  accountId      String
  periodMonth    Int
  periodYear     Int
  saldoStatement Decimal            @db.Decimal(15, 2)
  saldoBook      Decimal            @db.Decimal(15, 2)
  selisih        Decimal            @db.Decimal(15, 2)
  catatan        String?
  buktiUrl       String?
  status         RekonsiliasiStatus @default(DRAFT)
  createdById    String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  companyId      String
  account        Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  company        Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy      User               @relation("RekonsiliasiCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([accountId, periodMonth, periodYear], map: "rekonsiliasi_kas_account_period_key")
  @@index([companyId])
  @@index([periodYear, periodMonth], map: "rekonsiliasi_kas_period_idx")
  @@map("rekonsiliasi_kas")
}

model KasKategori {
  id           String         @id @default(cuid())
  nama         String
  key          String
  jenis        JenisKas
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  accountId    String?
  companyId    String
  account      Account?       @relation(fields: [accountId], references: [id])
  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  kasTransaksi KasTransaksi[]

  @@unique([companyId, key])
  @@index([companyId])
  @@map("kas_kategori")
}

model KasTransaksi {
  id          String      @id @default(cuid())
  tanggal     DateTime    @default(now())
  jenis       JenisKas
  kategoriKey String
  deskripsi   String
  jumlah      Decimal     @db.Decimal(15, 2)
  kasJenis    String      @default("TUNAI")
  buktiUrl    String?
  inputOlehId String
  isApproved  Boolean     @default(true)
  referensiId String?
  createdAt   DateTime    @default(now())
  companyId   String
  kategoriId  String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inputOleh   User        @relation(fields: [inputOlehId], references: [id])
  kat         KasKategori @relation(fields: [kategoriId], references: [id])

  @@index([companyId])
  @@index([kategoriId])
  @@map("kas_transaksi")
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  entityType String
  entityId   String?
  action     AuditAction
  beforeData Json?
  afterData  Json?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())
  actor      User?       @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

model ApprovalLog {
  id            String             @id @default(cuid())
  entityType    ApprovalEntityType
  entityId      String
  status        ApprovalStatus     @default(PENDING)
  catatan       String?
  requestedById String
  approvedById  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  approvedBy    User?              @relation("ApprovalApprover", fields: [approvedById], references: [id])
  requestedBy   User               @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([requestedById, createdAt])
  @@map("approval_logs")
}

model KolektorTarget {
  id                 String   @id @default(cuid())
  kolektorId         String
  periodMonth        Int
  periodYear         Int
  targetTagihan      Decimal  @db.Decimal(15, 2)
  realisasiTagihan   Decimal  @default(0) @db.Decimal(15, 2)
  targetKunjungan    Int      @default(0)
  realisasiKunjungan Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  companyId          String
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  kolektor           User     @relation("KolektorTargetUser", fields: [kolektorId], references: [id], onDelete: Cascade)

  @@unique([kolektorId, periodMonth, periodYear])
  @@index([periodYear, periodMonth])
  @@index([companyId])
  @@map("kolektor_targets")
}

model Notifikasi {
  id        String          @id @default(cuid())
  userId    String?
  jenis     NotifikasiJenis
  judul     String
  pesan     String
  link      String?
  isRead    Boolean         @default(false)
  readAt    DateTime?
  createdAt DateTime        @default(now())
  companyId String
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User?           @relation("UserNotifikasi", fields: [userId], references: [id])

  @@index([userId, isRead, createdAt])
  @@index([companyId])
  @@map("notifikasi")
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("app_settings")
}

model CompanySetting {
  id        String   @id @default(cuid())
  companyId String
  key       String
  value     Json
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
  @@index([key])
  @@map("company_settings")
}

enum RoleType {
  ADMIN
  TELLER
  KOLEKTOR
  SURVEYOR
  MANAGER
  PIMPINAN
  AKUNTANSI
  SUPER_ADMIN
  OWNER
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum StatusNasabah {
  AKTIF
  NON_AKTIF
  KELUAR
}

enum JenisPinjaman {
  REGULAR
  MIKRO
  USAHA
}

enum TenorType {
  BULANAN
  MINGGUAN
}

enum StatusPengajuan {
  DRAFT
  DIAJUKAN
  DISURVEY
  DISETUJUI
  DITOLAK
  DICAIRKAN
  SELESAI
}

enum StatusPinjaman {
  AKTIF
  MENUNGGAK
  MACET
  LUNAS
}

enum MetodeBayar {
  TUNAI
  TRANSFER
}

enum JenisKas {
  MASUK
  KELUAR
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalSourceType {
  PEMBAYARAN
  PENCAIRAN
  KAS
  SIMPANAN
  ADJUSTMENT
  REVERSAL
  DEMO_IMPORT
}

enum JournalStatus {
  DRAFT
  POSTED
  VOIDED
}

enum RekonsiliasiStatus {
  DRAFT
  SELESAI
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  DISBURSE
  PAYMENT
  CASH
  LOGIN
  LOGOUT
}

enum ApprovalEntityType {
  PENGAJUAN
  PEMBAYARAN
  KAS
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotifikasiJenis {
  JATUH_TEMPO
  TUNGGAKAN
  APPROVAL
  KAS
  REMINDER
  SYSTEM
}
